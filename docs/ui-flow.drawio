        <mxCell id="c-admin" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3E4C59;dashed=1;dashPattern=8 4;align=center;verticalAlign=top;fontColor=#26313B;fontStyle=1;fontSize=12;spacingTop=10;spacingLeft=10;spacingRight=10;arcSize=4;" value="&lt;div dir=&#39;rtl&#39;&gt;מסלול מנהל — זמין רק להרשאת Admin (נפתח מהסרגל העליון במסך הבית)&lt;/div&gt;" vertex="1">
