# Work4U frontend — environment configuration
# Copy to `.env` and fill in once the AWS backend is deployed.
# With VITE_USE_MOCK=true (the default) the app runs fully offline on mock data
# and NONE of the values below are required.

# ── Integration toggle ──────────────────────────────────────────────
# "true"  → use the in-app mock adapter (no AWS needed) — default.
# "false" → call the real backend (Cognito + API Gateway + S3) using the values below.
VITE_USE_MOCK=true

# ── API Gateway ─────────────────────────────────────────────────────
# Base URL of the deployed REST API (no trailing slash). See api-contract.md §2.
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/dev
VITE_API_BASE_URL=

# ── Amazon Cognito (User Pool) ──────────────────────────────────────
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# ── Amazon S3 (venue photos) ────────────────────────────────────────
# Used only for the optional Amplify Storage path; the contract's
# presigned-URL upload flow does not require this.
VITE_S3_BUCKET=
