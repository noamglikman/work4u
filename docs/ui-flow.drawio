        <mxCell id="ch-rating-err" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE9E7;strokeColor=#D6453D;fontColor=#A3271F;align=center;verticalAlign=middle;fontSize=10.5;arcSize=30;" value="✗ שליחת הדיווח נכשלה" vertex="1">
          <mxGeometry height="40" width="185" x="735" y="1282" as="geometry" />
        </mxCell>
        <mxCell id="s-history" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF3FA;strokeColor=#1F3A66;align=right;verticalAlign=top;spacingLeft=14;spacingRight=14;spacingTop=12;fontColor=#16263F;fontSize=12;arcSize=6;" value="&lt;div dir=&#39;rtl&#39;&gt;&lt;b&gt;מסך 7 · היסטוריית דירוגים&lt;/b&gt;&lt;br&gt;&lt;br&gt;• רשימה: מתחם · תאריך · עומס · Wi-Fi/5 · רעש/5&lt;br&gt;• מחיקת דירוג (פח)&lt;br&gt;• נגיש מהסרגל העליון (&#39;הדירוגים שלי&#39;)&lt;br&gt;• לחיצה על פריט → מסך 4&lt;/div&gt;" vertex="1">
