{
  "name": "work4u-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Work4U web frontend — find the perfect workspace. React + Vite, ready for AWS (Cognito + API Gateway + S3) integration.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "tsc -b --noEmit",
    "smoke": "esbuild scripts/smoke.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/w4u-smoke.mjs --log-level=warning && node node_modules/.cache/w4u-smoke.mjs"
  },
  "dependencies": {
    "aws-amplify": "^6.6.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
